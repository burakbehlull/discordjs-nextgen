{
  "name": "discordjs-nextgen",
  "version": "1.1.2",
  "description": "Simple and powerful Discord bot library",
  "homepage": "https://discordjs-nextgen.vercel.app",
  "repository": {
    "url": "https://github.com/burakbehlull/discordjs-nextgen"
  },

  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "ts-node example/botv3.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "library",
    "discordjs-nextgen"
  ],
  "author": "Burak <@burakbehlull>",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
